{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:e2e-verification:schema:evidence:v1",
  "title": "E2E verification step evidence",
  "type": "object",
  "required": [
    "contract_version",
    "step_id",
    "harness",
    "status",
    "risk",
    "started_at",
    "finished_at",
    "summary",
    "findings",
    "artifacts",
    "cleanup",
    "recommended_next_steps"
  ],
  "properties": {
    "contract_version": {"const": "1.0"},
    "step_id": {"type": "string", "minLength": 1},
    "harness": {"type": "string", "minLength": 1},
    "status": {"enum": ["PASS", "FAIL", "REVIEW", "BLOCKED", "SKIP"]},
    "risk": {"enum": ["read-only", "download", "write", "destructive", "external-send"]},
    "started_at": {"type": "string", "format": "date-time"},
    "finished_at": {"type": "string", "format": "date-time"},
    "summary": {"type": "object", "additionalProperties": {"type": "integer", "minimum": 0}},
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "status", "title", "message", "severity", "evidence"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "status": {"enum": ["PASS", "FAIL", "REVIEW", "BLOCKED", "SKIP"]},
          "title": {"type": "string", "minLength": 1},
          "message": {"type": "string"},
          "severity": {"type": "string"},
          "evidence": {"type": "array", "items": {"type": "string"}}
        },
        "additionalProperties": false
      }
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["kind", "path", "description", "redacted"],
        "properties": {
          "kind": {"type": "string", "minLength": 1},
          "path": {"type": "string", "minLength": 1},
          "description": {"type": "string"},
          "redacted": {"type": "boolean"}
        },
        "additionalProperties": false
      }
    },
    "cleanup": {
      "type": "object",
      "required": ["required", "status", "message"],
      "properties": {
        "required": {"type": "boolean"},
        "status": {"enum": ["PASS", "FAIL", "REVIEW", "BLOCKED", "SKIP"]},
        "message": {"type": "string"}
      },
      "additionalProperties": false
    },
    "recommended_next_steps": {"type": "array", "items": {"type": "string"}},
    "metadata": {"type": "object"}
  },
  "additionalProperties": false
}
