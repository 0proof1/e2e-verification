{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:e2e-verification:schema:ui-audit:v1",
  "title": "UI evidence audit configuration",
  "type": "object",
  "required": ["name", "read_only", "viewports", "artifacts", "roles", "cases", "state_contract"],
  "properties": {
    "draft_contract_version": {"enum": ["ui-audit-v1"]},
    "name": {"type": "string", "minLength": 1},
    "profile": {"type": "string"},
    "read_only": {"const": true},
    "viewports": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "width", "height"],
        "properties": {
          "name": {"type": "string", "minLength": 1},
          "width": {"type": "integer", "minimum": 320},
          "height": {"type": "integer", "minimum": 320}
        },
        "additionalProperties": false
      }
    },
    "artifacts": {
      "type": "array",
      "contains": {"const": "viewport"},
      "allOf": [{"contains": {"const": "full_page"}}],
      "items": {"enum": ["viewport", "full_page"]},
      "uniqueItems": true
    },
    "measurements": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "safety": {
      "type": "object",
      "properties": {
        "allowed_methods": {
          "type": "array",
          "items": {"enum": ["GET", "HEAD", "OPTIONS"]},
          "uniqueItems": true
        },
        "block_external_hosts": {"type": "boolean"}
        ,"allowed_external_hosts": {
          "type": "array",
          "items": {"type": "string", "pattern": "^[A-Za-z0-9.-]+$"},
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    },
    "roles": {"type": "object", "minProperties": 1, "additionalProperties": {"type": "object"}},
    "cases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["page", "role", "route", "title", "states"],
        "properties": {
          "page": {"type": "string", "minLength": 1},
          "role": {"type": "string", "minLength": 1},
          "route": {"type": "string", "minLength": 1},
          "title": {"type": "string", "minLength": 1},
          "menu": {"type": "string", "minLength": 1},
          "navigation": {
            "type": "object",
            "required": ["source_route", "menu"],
            "properties": {
              "source_route": {"type": "string", "minLength": 1},
              "menu": {"type": "string", "minLength": 1}
            },
            "additionalProperties": false
          },
          "title_selector": {"type": "string", "minLength": 1},
          "data_selector": {"type": "string", "minLength": 1},
          "states": {
            "type": "array",
            "minItems": 1,
            "items": {"enum": ["loading", "data", "empty", "error"]},
            "uniqueItems": true
          }
        },
        "additionalProperties": false
      }
    },
    "state_contract": {"type": "object", "minProperties": 1, "additionalProperties": {"type": "object"}}
  },
  "additionalProperties": false
}
