{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:e2e-verification:schema:run:v1",
  "title": "E2E verification run state",
  "type": "object",
  "required": ["contract_version", "run_id", "workflow", "workflow_digest", "profile", "status", "started_at", "updated_at", "steps"],
  "properties": {
    "contract_version": {"const": "1.0"},
    "run_id": {"type": "string", "minLength": 1},
    "workflow": {"type": "string", "minLength": 1},
    "workflow_digest": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "profile": {"type": "string"},
    "status": {"enum": ["PASS", "FAIL", "REVIEW", "BLOCKED", "SKIP"]},
    "started_at": {"type": "string", "format": "date-time"},
    "updated_at": {"type": "string", "format": "date-time"},
    "finished_at": {"type": "string", "format": "date-time"},
    "steps": {
      "type": "object",
      "additionalProperties": {"$ref": "urn:e2e-verification:schema:evidence:v1"}
    }
  },
  "additionalProperties": false
}
