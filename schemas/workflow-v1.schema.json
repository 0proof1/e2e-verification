{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:e2e-verification:schema:workflow:v1",
  "title": "E2E verification workflow",
  "type": "object",
  "required": ["version", "name", "steps"],
  "properties": {
    "version": {"const": 1},
    "name": {"type": "string", "minLength": 1},
    "profile": {"type": "string"},
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "harness"],
        "properties": {
          "id": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"},
          "harness": {"type": "string", "minLength": 1},
          "needs": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
          "args": {"type": "object"},
          "risk": {"enum": ["read-only", "download", "write", "destructive", "external-send"]},
          "approval": {"type": "string"},
          "retries": {"type": "integer", "minimum": 0},
          "timeout_seconds": {"type": "integer", "minimum": 1}
          ,"when": {"enum": ["success", "failure", "always"]},
          "idempotent": {"type": "boolean"}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
